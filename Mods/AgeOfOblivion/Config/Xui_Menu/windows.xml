<config>
	<!-- <append xpath="/windows/window[@name='newContinueGame']/rect[@name='rightPanel']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@tab_key='xuiGameSettingsGeneral']/grid"> -->
		<!-- <rect/> -->
		<!-- <gameoption name="MaxSpawnedZombies" title="goMaxSpawnedZombies" value_wrap="false" value_type="int" values="0, 15, 30, 45, 64, 75, 90, 100" display_names="" value_localization_prefix="goZombie"/> -->
		<!-- <gameoption name="MaxSpawnedAnimals" title="goMaxSpawnedAnimals" value_wrap="false" value_type="int" values="0, 15, 30, 45, 50, 60, 75, 90, 100" display_names="" value_localization_prefix="goAnimal"/> -->
		<!-- <gameoption name="LandClaimCount" title="goLandClaimCount" value_wrap="false" value_type="int" values="1, 2, 3, 4, 5" display_names="" value_localization_prefix="goLandClaimCountValue"/> -->
	<!-- </append> -->
	
	<set xpath="/windows/window[@name='newContinueGame']/rect[@name='rightPanel']/rect[@name='tabs']/rect[@name='tabsHeader']/grid[@name='tabButtons']/@cols">5</set>
	
	<append xpath="/windows/window[@name='newContinueGame']/rect[@name='rightPanel']/rect[@name='tabs']/rect[@name='tabsContents']">
		<rect controller="TabSelectorTab" tab_key="Specific">
			<grid pos="6,-51" rows="14" cell_width="525" cell_height="45" repeat_content="false" arrangement="vertical" >
				<gameoption name="MaxSpawnedZombies" title="goMaxSpawnedZombies" value_wrap="false" value_type="int" values="0, 15, 30, 45, 64, 75, 90, 100" display_names="" value_localization_prefix="goZombie"/>
				<gameoption name="MaxSpawnedAnimals" title="goMaxSpawnedAnimals" value_wrap="false" value_type="int" values="0, 15, 30, 45, 50, 60, 75, 90, 100" display_names="" value_localization_prefix="goAnimal"/>
				<gameoption name="LandClaimCount" title="goLandClaimCount" value_wrap="false" value_type="int" values="1, 2, 3, 4, 5" display_names="" value_localization_prefix="goLandClaimCountValue"/>
			</grid>
		</rect>
	</append>
	
	<set xpath="/windows/window[@name='menuBackground']/texture/@texture">@modfolder:Textures/menu/FLEmenu.png</set>

	<remove xpath="/windows/window[@name='mainMenu']" />
	<remove xpath="/windows/window[@name='editingTools']" />
	<remove xpath="/windows/window[@name='newsWindow']" />
	<remove xpath="/windows/window[@name='mainMenuQuit']" />

	<append xpath="/windows" >
		<window name="newsWindow" anchor="RightCenter" pos="-900,-130" width="875" height="300" controller="NewsWindow" cursor_area="true" browse_sound="Sounds/Crafting/craft_click_recipe" on_scroll="true">
			<panel name="header" pos="0,0" height="80" depth="1" backgroundcolor="96,96,96,180" bordercolor="[black]" borderthickness="3" pivot="topleft" visible="{has_news_provider}">
				<rect visible="{has_news}">

					<label depth="3" name="headline" pos="40,-6" width="420" height="42" font_size="36" text="AOO A7.10.21.2 Stable" />

				</rect>
			</panel>

			<panel name="content" pos="0,-78" height="300" depth="1" backgroundcolor="96,96,96,160" bordercolor="[black]" borderthickness="3" pivot="topleft" visible="{has_news_provider}">
				<rect visible="{has_news}">
					<label depth="3" name="contentText" pos="8,-8" width="785" height="295" spacing_y="4" text_key="aoonews" />
					<rect name="btnLink" depth="3" pos="370,-270" width="484" height="26" enabled_font_color="[labelColor]" hovered_font_color="[hoverColor]" disabled_font_color="[disabledLabelColor]" controller="SimpleButton" button_enabled="true" font_size_default="24" font_size_hover="24" visible="{has_link}">
						<button name="clickable" sprite="ui_game_popup" defaultcolor="0,0,0,10" hovercolor="0,0,0,10" type="sliced" hoverscale="1.0" pivot="left" sound="[default_click]" tooltip="https://tinyurl.com/AOOINFO" />
						<label depth="2" name="btnLabel" justify="right" text_key="xuiNewsReadMore" effect="outline" pivot="left" font_size="24" upper_case="true" />
					</rect>					

				</rect>
			
				<rect visible="{# !has_news}">
					<label depth="3" text_key="xuiLoadingNews" pos="250,-235" font_size="36" justify="center" pivot="center" />
				</rect>
			</panel>
		</window>




	<window name="mainMenu" pos="-725,0" width="300" height="1080" panel="Left" controller="MainMenu" cursor_area="true"  windows_to_open_globally="menuBackground,mainMenuDiscordButton,-discordInteractions" >
			<panel name="background"  pos="-725,60" height="1080" width="300" depth="1"  backgroundspritename="MainMenuBackground" globalopacity="false" >
				<grid pos="150,-325" rows="13" cell_width="300" cell_height="70" depth="2" repeat_content="false" arrangement="vertical" controller="MainMenuButtons" >
					<mainmenubutton name="btnNewGame" pivot="center" width="300" height="45" caption_key="xuiNewGame" backgroundcolor="50,50,50" />
					<mainmenubutton name="btnContinueGame" pivot="center" width="300" height="45" caption_key="xuiContinueGame" />
					<mainmenubutton name="btnConnectToServer" pivot="center" width="300" height="45" caption_key="xuiConnectToServer" />
					<mainmenubutton name="btnEditingTools" pivot="center" width="300" height="45" caption_key="xuiEditingTools" />
					<mainmenubutton name="btnOptions" pivot="center" width="300" height="45" caption_key="xuiOptions" />
					<mainmenubutton name="btnCredits" pivot="center" width="300" height="45" caption_key="xuiCredits" />
					<mainmenubutton name="btnQuit" pivot="center" width="300" height="45" caption_key="xuiQuit" />
				</grid>
			</panel>
		</window>
	
	
	<window name="editingTools" pos="-725,0" width="300" height="1080" panel="Left" controller="EditingTools" cursor_area="true">
		<panel name="background"  pos="-725,60" height="1080" width="300" depth="1"  backgroundspritename="MainMenuBackground" globalopacity="false" >
		<grid name="buttons" pos="150,-325" rows="13" cell_width="300" cell_height="70" repeat_content="false" arrangement="vertical" >
			<mainmenubutton name="btnRwgPreviewer" pivot="center" width="300" height="50" caption_key="xuiRwgPreviewer" visible="false"/>
			<mainmenubutton name="btnPrefabEditor" pivot="center" width="300" height="50" caption_key="xuiPrefabEditor" />
			<mainmenubutton name="btnWorldEditor" pivot="center" width="300" height="50" caption_key="xuiWorldEditor" />
		</grid>
		
		<widget pos="45,-550" >
			<mainmenubutton name="btnBack" pivot="left" width="200" height="50" caption_key="xuiBack" />
		</widget>
		</panel>
	</window>	
	
	</append>


</config>