<config>

	<append xpath="/materials/material[@id='MfoodRawMeat']">
		<property name="forge_category" value="meat"/>
	</append>

	<append xpath="/materials">

		<material id="Magpaper">
			<property name="damage_category" value="cloth"/>
			<property name="surface_category" value="cloth"/>
			<property name="forge_category" value="scrapMagazine"/>
			<property name="Hardness" type="float" value="1"/>
			<property name="stepsound" value="wood"/>
			<property name="stability_glue" value="20"/>
			<property name="Mass" type="int" value="1"/>
			<property name="MaxDamage" value="1"/>
			<property name="Experience" value="2"/>
		</material>

		<material id="MCarcass">
			<property name="damage_category" value="organic"/>
			<property name="surface_category" value="organic"/>
			<property name="Experience" value="2"/>
			<property name="forge_category" value="meat"/>
		</material>
		
		<material id="MRottingFlesh">
			<property name="damage_category" value="organic"/>
			<property name="surface_category" value="organic"/>
			<property name="Experience" value="2"/>
			<property name="forge_category" value="rottingFlesh"/>
		</material>

		<material id="MZombieCarcass">
			<property name="damage_category" value="organic"/>
			<property name="surface_category" value="organic"/>
			<property name="Experience" value="2"/>
			<property name="forge_category" value="rottingFlesh"/>
		</material>

	</append>
	
</config>