<config>

	<!-- ===== Vanilla Animals ===== -->

	<!-- Stag -->
	<remove xpath="/entity_classes/entity_class[@name='animalStag']/drop[not(@tool_category)]"/>
	<append xpath="/entity_classes/entity_class[@name='animalStag']">
		<property name="CorpseBlock" value="blockCarcassStag"/>
	</append>
	
	<!-- Doe -->
	<remove xpath="/entity_classes/entity_class[@name='animalDoe']/drop[not(@tool_category)]"/>
	<append xpath="/entity_classes/entity_class[@name='animalDoe']">
		<property name="CorpseBlock" value="blockCarcassDoe"/>
	</append>
	
	<!-- Rabbit -->
	<setattribute xpath="/entity_classes/entity_class[@name='animalRabbit']/drop[@name='resourceBone' and @tag='butcherHarvest']" name="count">2</setattribute>
	<remove xpath="/entity_classes/entity_class[@name='animalRabbit']/drop[@name='resourceBone' and @tag='allToolsHarvest']" />
	<insertAfter xpath="/entity_classes/entity_class[@name='animalRabbit']/drop[last()]">
		<drop event="Harvest" name="resourceRabbitsFootAOO" tag="butcherHarvest" count="2" prob=".05"/>
	</insertAfter>
	
	<!-- Chicken -->
	<setattribute xpath="/entity_classes/entity_class[@name='animalChicken']/drop[@name='resourceBone' and @tag='butcherHarvest']" name="count">2</setattribute>
	<remove xpath="/entity_classes/entity_class[@name='animalChicken']/drop[@name='resourceBone' and @tag='allToolsHarvest']" />
	<insertAfter xpath="/entity_classes/entity_class[@name='animalChicken']/drop[last()]">
		<drop event="Harvest" name="foodRawChickenBreastAOO" tag="butcherHarvest" count="2" prob=".25"/>
		<drop event="Harvest" name="foodRawChickenLegsandWingsAOO" tag="butcherHarvest" count="2" prob=".25"/>
		<drop event="Harvest" name="resourceChickenFeetAOO" tag="butcherHarvest" count="1" prob=".25"/>
	</insertAfter>
	
	<!-- Bear -->
	<remove xpath="/entity_classes/entity_class[@name='animalBear']/drop[not(@tool_category)]"/>
	<append xpath="/entity_classes/entity_class[@name='animalBear']">
		<property name="CorpseBlock" value="blockCarcassBear"/>
	</append>
	<!-- Small Bear-->
	<remove xpath="/entity_classes/entity_class[@name='animalBearSmall']/drop[not(@tool_category)]"/>
	
	<!-- Zombie Bear -->
