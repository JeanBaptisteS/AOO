<config>

	<append xpath="/blocks">
		
		<block name="blockCarcassTemplate">
			<property name="CreativeMode" value="None"/>
			<property name="Material" value="MCarcass"/>
			<property name="IndexName" value="challenge_gore"/>
			<property name="Shape" value="ModelEntity"/>
			<property name="CustomIcon" value="goreBlockAnimal"/>
			<property name="Model" value="@:Entities/Gore/animalRemainsGorePrefab.prefab"/>
			<property name="ImposterExclude" value="true"/>
			<property name="ImposterDontBlock" value="true"/>
			<property name="Density" value="0.9"/>
			<property name="WaterFlow" value="permitted"/>
			<property name="Collide" value="melee,bullet,arrow,rocket"/>
			<property name="IsTerrainDecoration" value="true"/>
			<property name="FallDamage" value=".9"/>
			<property name="MaxDamage" value="100"/>
			<property name="SortOrder1" value="B265"/>
			<property name="SortOrder2" value="0000"/>
			<property name="Tags" value="challenge_gore"/>
			<property name="FilterTags" value="MC_building,SC_decor"/>
		</block>
		
		<block name="blockCarcassStag">
			<property name="Extends" value="blockCarcassTemplate"/>
			<property name="CreativeMode" value="Player"/>
			<drop event="Destroy" name="itemCarcassStag" count="1" tag="butcherHarvest"/>
		</block>
		
		<block name="blockCarcassDoe">
