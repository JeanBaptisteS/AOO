			<property name="UserSpawnType" value="None"/>
			<property name="ModelType" value="Standard"/>
			<property name="HandItem" value="meleeHandWeeper1"/>
			<property name="Faction" value="undead"/>
			<property name="EntityFlags" value="zombie"/>
			<property name="IsEnemyEntity" value="true"/>
			<property name="Parent" value="Enemies"/>
			<property name="LookAtAngle" value="0"/>
			<property name="HasRagdoll" value="false"/>
			<property name="RootMotion" value="false"/>
			<property name="PhysicsBody" value=""/>
			
			<property name="CompassIcon" value="ui_game_symbol_enemy_dot"/>
			<property name="CompassUpIcon" value="ui_game_symbol_enemy_dot_up"/>
			<property name="CompassDownIcon" value="ui_game_symbol_enemy_dot_down"/>
			<property name="TrackerIcon" value="ui_game_symbol_run"/>
			
            <property name="DismemberMultiplierHead" value="0"/>
	        <property name="DismemberMultiplierArms" value="0"/>
	        <property name="DismemberMultiplierLegs" value="0"/>
			<property name="ExperienceGain" value="1200"/>
			<property name="LootDropEntityClass" value="EntityLootContainerStrong,1,EntityLootContainerPlague,1"/>
			<property name="TimeStayAfterDeath" value="300"/>
			<property name="DeadBodyHitPoints" value="500"/>
			
			<property name="SurfaceCategory" value="organic"/>
			<property name="ParticleOnDeath" value="blood_death"/>

			<property name="SoundRandom" value="WeeperMiscAOO"/>
			<property name="SoundAlert" value="WeeperMiscAOO"/>
			<property name="SoundHurt" value="WeeperHurtAOO"/>
			<property name="SoundDeath" value="WeeperDeathAOO"/>
			<property name="SoundAttack" value="WeeperAttckAOO"/>
			<property name="SoundSense" value="WeeperMiscAOO"/>
			<property name="SoundGiveUp" value="WeeperMiscAOO"/>
			
