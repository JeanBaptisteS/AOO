				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="skingvar" operation="set" value="randomint(1,4)"/>

				<triggered_effect trigger="onSelfBuffUpdate" action="SetTransformActive" active="true" transform_path="Skeleton1"> 
					<requirement name="CVarCompare" cvar="skingvar" operation="Equals" value="1"/>
				</triggered_effect>	
				<triggered_effect trigger="onSelfBuffUpdate" action="SetTransformActive" active="true" transform_path="Skeleton2"> 
					<requirement name="CVarCompare" cvar="skingvar" operation="Equals" value="2"/>
				</triggered_effect>	
				<triggered_effect trigger="onSelfBuffUpdate" action="SetTransformActive" active="true" transform_path="Skeleton3"> 
					<requirement name="CVarCompare" cvar="skingvar" operation="Equals" value="3"/>
				</triggered_effect>	
				<triggered_effect trigger="onSelfBuffUpdate" action="SetTransformActive" active="true" transform_path="Skeleton4"> 
					<requirement name="CVarCompare" cvar="skingvar" operation="Equals" value="4"/>
				</triggered_effect>	
		
				<triggered_effect trigger="onOtherDamagedSelf" 	action="ModifyStats" stat="Health" operation="add" value="200">
					<requirement name="CVarCompare" target="self" cvar="zRandomCVar" operation="LTE" value="10"/>
				</triggered_effect>					
				<triggered_effect trigger="onOtherDamagedSelf" 	action="AddBuff" buff="buffSkeletonEnraged" >
					<requirement name="CVarCompare" target="self" cvar="zRandomCVar" operation="LTE" value="10"/>
				</triggered_effect>	
			</effect_group>	
			
			<effect_group name="SkeletonKingVar1"> 		
				<requirement name="CVarCompare" cvar="skingvar" operation="Equals" value="1"/>			
				<passive_effect name="DamageModifier" operation="perc_add" value=".5" />
			</effect_group>
			<effect_group name="SkeletonKingVar2"> 			
				<requirement name="CVarCompare" cvar="skingvar" operation="Equals" value="2"/>	
				<passive_effect name="HealthMax" operation="perc_add" value=".5"/>
			</effect_group>				
			<effect_group name="SkeletonKingVar3"> 			
				<requirement name="CVarCompare" cvar="skingvar" operation="Equals" value="3"/>	
				<passive_effect name="DamageModifier" operation="perc_add" value=".5" />
			</effect_group>	
			<effect_group name="SkeletonKingVar4"> 			
				<requirement name="CVarCompare" cvar="skingvar" operation="Equals" value="4"/>	
				<passive_effect name="HealthMax" operation="perc_add" value=".5"/>
			</effect_group>				
			<effect_group name="SkeletonBoss"> 
				<triggered_effect trigger="onSelfDamagedOther" action="AddBuff" target="other"  buff="buffFear">
					<requirement name="CVarCompare" target="self" cvar="zRandomCVar" operation="LTE" value="20"/>
				</triggered_effect>					
				<triggered_effect trigger="onSelfAttackedOther" action="AddBuff" target="other"  buff="buffSkeletonBlur">
					<requirement name="CVarCompare" target="self" cvar="zRandomCVar" operation="LTE" value="10"/>
				</triggered_effect>									
			</effect_group>			
		</buff>	
		
	<!-- ============= EFFECTS ============= -->
	
		<buff name="buffSkeletonEnraged" hidden="true">
			<stack_type value="ignore"/>
			<duration value="15"/>
			<effect_group>
				<triggered_effect trigger="onSelfBuffUpdate" action="SetTransformActive" active="true" transform_path="Skeleton4/Head3/Effect_16"> 
					<requirement name="CVarCompare" cvar="skingvar" operation="Equals" value="4"/>
				</triggered_effect>					
				<passive_effect name="WalkSpeed" operation="base_set" value="2"/>
				<passive_effect name="RunSpeed" operation="base_set" value="2.5"/> 
				<passive_effect name="HealthChangeOT" operation="base_set" value="4"/>  <!-- heal x point of (red) health / minute -->
				<passive_effect name="DamageModifier" operation="perc_add" value="2"/>
				<passive_effect name="PhysicalDamageResist" operation="base_set" value="40" />				
				<triggered_effect trigger="onSelfBuffRemove" action="SetTransformActive" active="false" transform_path="Effect_16"/>
			</effect_group>
		</buff>

		<buff name="buffSkeletonBlur" hidden="true">
			<stack_type value="ignore"/>
			<duration value="1"/>
			<effect_group>
				<triggered_effect trigger="onSelfBuffStart" action="CallGameEvent" event="buff_blur" >
				</triggered_effect>	
			</effect_group>
		</buff>		
		
		<buff name="zombieWightRadiationShowerAOEEffect" icon="ui_game_symbol_radiation" icon_color="255,0,0" icon_blink="true">
			<damage_type value="radiation"/>
			<stack_type value="replace"/>
			<duration value="4"/>
			<update_rate value="1"/>
			<effect_group>
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyStats" stat="Health" operation="subtract" value=".5"/>
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="RadiationSignal" operation="add" value="1"/>
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="RadiationSignal" operation="set" value="0">
					<requirement name="CVarCompare" cvar="RadiationSignal" operation="Equals" value="2"/>
				</triggered_effect>
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="RadiationSignal" operation="set" value="0"/>
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyScreenEffect" intensity=".15" fade=".5" effect_name="Hot">
					<requirement name="CVarCompare" cvar="RadiationSignal" operation="Equals" value="1"/>
				</triggered_effect>
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyScreenEffect" intensity="0" fade=".5" effect_name="Hot">
					<requirement name="CVarCompare" cvar="RadiationSignal" operation="Equals" value="0"/>
				</triggered_effect>
				<triggered_effect trigger="onSelfBuffRemove" action="ModifyScreenEffect" intensity="0" fade="1" effect_name="Hot"/>
				<triggered_effect trigger="onSelfBuffStart" action="ModifyScreenEffect" effect_name="Radiation" intensity=".3" fade="2"/>
				<triggered_effect trigger="onSelfDied" action="ModifyScreenEffect" effect_name="Radiation" intensity="0" fade="0"/>
				<triggered_effect trigger="onSelfBuffRemove" action="ModifyScreenEffect" effect_name="Radiation" intensity="0" fade="2"/>
			</effect_group>
		</buff>

		<buff name="buffFear" >
			<stack_type value="ignore"/>
			<duration value="30"/>		
			<effect_group>
				<triggered_effect trigger="onSelfBuffStart" action="PlaySound" sound="Scream" play_in_head="true"/>		
				<triggered_effect trigger="onSelfBuffRemove" action="PlaySound" sound="Scream" play_in_head="true"/>					
			<!--	<triggered_effect trigger="onSelfBuffStart" action="CallGameEvent" event="action_Fear" allow_client_call="true"/> 
				<triggered_effect trigger="onSelfBuffRemove" action="ModifyScreenEffect" intensity="0" fade="1" effect_name="Dark"/> -->				
				<passive_effect name="WaterChangeOT" operation="perc_add" value="-.5"/>
				<passive_effect name="FoodChangeOT" operation="perc_add" value="-.5"/> 
				<passive_effect name="StaminaLoss" operation="perc_add" value="-.07"/>
			</effect_group>	
		</buff>	

		<buff name="buffDontMoveAOO" hidden="true" remove_on_death="true">
			<stack_type value="ignore"/>
			<duration value="2"/>
			
			<effect_group>
				<passive_effect name="DisableMovement" operation="base_set" value="1" />
			</effect_group>
		</buff>
		
       <buff name="buffDamagePlayerAOO" hidden="true">
		<duration value="2"/>
			<update_rate value=".5"/>
			<effect_group>
			<requirement name="EntityTagCompare" target="self" tags="player"/>
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyStats" stat="Health" operation="subtract" value="5"/>	

			</effect_group>
		</buff>

		<buff name="buffBanshee" hidden="true">
