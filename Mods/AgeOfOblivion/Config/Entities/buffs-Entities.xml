<config>

	<append xpath="/buffs">
	
	<!-- ============= GENERAL ZOMBIE BUFFS ============= -->
	
		<buff name="buffZombie" hidden="true"> 
			<stack_type value="ignore"/>
			<update_rate value="1"/>				
			<effect_group> 
				<triggered_effect trigger="onSelfBuffStart" action="CallGameEvent" event="action_CheckPOI"/>			
			<!-- Set Random CVars for Multiple Use -->
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="DeathSpawnCVar" operation="set" value="randomint(1,100)"/>
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="DeathLootCVar" operation="set" value="randomint(1,100)"/>
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="zRandomCVar" operation="set" value="randomint(1,100)"/>
			<!-- Set Biome CVars for Use in Gameevents -->	
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="Biome" operation="set" value="1">	
					<requirement name="InBiome" biome="1"/>
				</triggered_effect>
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="Biome" operation="set" value="3">	
					<requirement name="InBiome" biome="3"/>
				</triggered_effect>				
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="Biome" operation="set" value="5">	
					<requirement name="InBiome" biome="5"/>
				</triggered_effect>				
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="Biome" operation="set" value="8">	
					<requirement name="InBiome" biome="8"/>
				</triggered_effect>
				<triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="Biome" operation="set" value="9">	
					<requirement name="InBiome" biome="9"/>
				</triggered_effect>	
				
			<!-- Call Game Events on Death -->
				<triggered_effect trigger="onOtherDamagedSelf" action="CallGameEvent" event="action_DeathSpawns">
				  <requirement name="StatCompareCurrent" stat="Health" operation="LTE" value="0"/>
				  <requirement name="IsAlive" target="self"/>
				</triggered_effect>	
			</effect_group>	
			<effect_group>	
				<requirement name="CVarCompare" target="self" cvar="EnemyPL" operation="GT" value="@LastEnemyPL"/>		
				<triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buffZombieUpdate"/>
			</effect_group>		
			<effect_group name="Player Level Effects">
				<passive_effect name="HealthMax" operation="perc_add" value="@ModifierHealth"/>
				<passive_effect name="DamageModifier" operation="perc_add" value="@Modifier1percent" />				
				<passive_effect name="ExperienceGain" operation="perc_add" value="@Modifier1percent"/>	
				<passive_effect name="LootDropProb" operation="perc_add" value="@ModifierLoot"/>				
			</effect_group>
			<effect_group name="Night Effects"> 
				<requirement name="IsNight" />
				<requirement name="RequirementIsBloodMoonDMT, SCore" invert="true"/>				
				<passive_effect name="HealthMax" operation="perc_add" value=".8,1.2"/>
				<passive_effect name="DamageModifier" operation="perc_add" value=".15,.35" />
				<passive_effect name="WalkSpeed" operation="perc_add" value=".15,.35"/>
				<passive_effect name="RunSpeed" operation="perc_add" value=".15,.35"/>
				<passive_effect name="PhysicalDamageResist" operation="base_add" value="10,15"/>
				<!-- <passive_effect name="HealthChangeOT" operation="base_add" value="2"/>		 -->
				<passive_effect name="ExperienceGain" operation="base_add" value="200"/>
