		<buff name="buffZombieUpdate" >
			<stack_type value="ignore"/>
			<duration value=".2"/>		
			<effect_group>
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="LastEnemyPL" operation="set" value="@EnemyPL"/>	
				<triggered_effect trigger="onSelfBuffRemove" action="AddBuff" buff="buffZombieModifiers"/>				
			</effect_group>	
		</buff>	

		<buff name="buffZombieModifiers" >
			<stack_type value="ignore"/>
			<duration value=".6"/>		
			<effect_group>
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="Modifier1percent" operation="set" value="@EnemyPL"/>	
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="Modifier1percent" operation="divide" value="100"/>	
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="Modifier2percent" operation="set" value="@EnemyPL"/>	
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="Modifier2percent" operation="divide" value="50"/>
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="ModifierHealth" operation="set" value="@EnemyPL"/>	
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="ModifierHealth" operation="divide" value="25"/>
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="ModifierLoot" operation="set" value="@EnemyPL"/>	
				<triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="ModifierLoot" operation="divide" value="250"/>				
				<triggered_effect trigger="onSelfBuffRemove" action="AddBuff" buff="buffZombieHealth"/>					
			</effect_group>	
		</buff>	
		<buff name="buffZombieHealth" >
