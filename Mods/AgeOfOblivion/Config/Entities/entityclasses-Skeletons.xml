<config>
	<append xpath="/entity_classes" >

		<entity_class name="zombieSkeletonBossTemplate_AOO" extends="zombieTemplateAOO">
			<property name="LookAtAngle" value="0"/>
			<property name="UserSpawnType" value="Menu"/>				
			<property name="RootMotion" value="true"/>
			<property name="DeadBodyHitPoints" value="500"/>
			<property name="ExperienceGain" value="4000"/> 
			<property name="HandItem" value="meleeSkeletonClub"/>
			<property name="Mesh" value="#@modfolder:Resources/NewEntities/AOO_Skeletons.unity3d?SkeletonKing.prefab"/>
			<property name="LootDropProb" value="1"/>
			<property name="LootDropEntityClass" value="EntityLootContainerBoss"/>
			<property name="TimeStayAfterDeath" value="300"/>
			<property name="MoveSpeed" value="0.2"/> 
			<property name="MoveSpeedAggro" value="0.55, .9"/> 
			<property name="MoveSpeedRand" value="-.1, .25"/> 
			<property name="SoundRandomTime" value="10"/> 
			<property name="SoundRandom" value="SkeletonKingRandomAOO"/>
			<property name="SoundAlertTime" value="25"/> 
			<property name="SoundAlert" value="SkeletonKingRandomAOO"/>
			<property name="SoundSense" value="SkeletonKingRandomAOO"/>
			<property name="SoundHurt" value="zombieMoanAOO"/>
			<property name="SoundDeath" value="zombieDeathAOO"/>
			<property name="SoundAttack" value="zombieGruntAOO"/>
			<property name="MaxViewAngle" value="360"/>
			<property name="SightRange" value="75"/> <!-- distance in m -->
			<effect_group name="Base Effects">
				<passive_effect name="HealthMax" operation="base_set" value="6666"/>
				<passive_effect name="HealthMax" operation="perc_set" value="1"/> 
			</effect_group>	
			<effect_group>
				<passive_effect name="WalkSpeed" operation="base_set" value=".4"/>
				<passive_effect name="RunSpeed" operation="base_set" value="1.2"/> 
				<passive_effect name="HealthChangeOT" operation="base_set" value="0.5"/>  
				<passive_effect name="DamageModifier" operation="perc_set" value="1"/>
				<passive_effect name="DamageModifier" operation="perc_add" value="2" tags="head"/>
				<passive_effect name="DismemberChance" operation="base_set" value=".005"/> 
				<passive_effect name="WaterMax" operation="base_set" value="100"/> 
				<passive_effect name="CrouchSpeed" operation="base_set" value=".3"/> 
				<passive_effect name="WalkSpeed" operation="base_set" value="0.75" tags="swimming"/>
				<passive_effect name="RunSpeed" operation="base_set" value="0.75" tags="swimming"/>
				<passive_effect name="Mobility" operation="base_set" value="1"/> 
				<passive_effect name="JumpStrength" operation="base_set" value="0.86"/> 
			</effect_group>		
			<effect_group>
				<passive_effect name="BuffResistance" operation="base_set" value="1" tags="buffInjuryBleeding,buffInjuryBleedingTwo,buffInjuryBleedingBarbedWire"/>
			</effect_group>			
				
		</entity_class>	

		<!-- ===== Skeleton Bosses ===== -->

